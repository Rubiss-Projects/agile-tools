{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @agile-tools/db exec prisma generate && pnpm --filter @agile-tools/web build",
  "crons": [
    {
      "path": "/api/hosted/cron/sync-watchdog",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "src/app/api/hosted/queues/sync/route.ts": {
      "maxDuration": 30,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "hosted-sync",
          "retryAfterSeconds": 60
        }
      ]
    },
    "src/app/api/hosted/queues/sync-tick/route.ts": {
      "maxDuration": 30,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "hosted-sync-tick",
          "retryAfterSeconds": 300
        }
      ]
    }
  }
}
