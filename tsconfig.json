{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "vitest.config.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "**/.next/**"
  ]
}