{
  "name": "agile-tools",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:contract": "vitest run --config tests/contract/vitest.config.ts",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:perf": "vitest run --config tests/integration/performance/vitest.config.ts",
    "dev": "pnpm -r --parallel dev"
  },
  "devDependencies": {
    "@agile-tools/db": "workspace:*",
    "@agile-tools/jira-client": "workspace:*",
    "@agile-tools/shared": "workspace:*",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.44.0",
    "@prisma/client": "^6.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.2",
    "msw": "^2.3.0",
    "testcontainers": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
