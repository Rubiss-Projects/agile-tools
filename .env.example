# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agile_tools

# Application
APP_BASE_URL=http://localhost:3000
# Optional for local production-mode smoke tests only.
# ALLOW_LOOPBACK_HTTP_BYPASS=true
ENCRYPTION_KEY=replace-with-a-32-byte-local-dev-only-key
SESSION_SECRET=replace-with-a-32-byte-local-dev-only-secret

# Sync
DEFAULT_SYNC_INTERVAL_MINUTES=10

# Logging
LOG_LEVEL=debug
