# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agile_tools
# Optional: when set, the database URL is read from the variable it names
# instead of DATABASE_URL. Useful for managed-service deployments that inject
# the PostgreSQL binding under an autogenerated variable (e.g. XYZ_POSTGRESQL_URI)
# that you cannot rename. The named variable must be set and non-empty.
# DATABASE_URL_ENV_VAR=XYZ_POSTGRESQL_URI

# Application
AUTH_PROVIDER=local_session
SYNC_BACKEND=pgboss
JIRA_CONNECTION_POLICY=self_hosted_tokens
# Recommended when running the production web container directly on localhost.
ALLOW_LOOPBACK_HTTP_BYPASS=true
# Enables the built-in local admin bootstrap flow on loopback hosts.
ALLOW_LOCAL_BOOTSTRAP=true
# Optional: pin docker-compose.consumer.yml to a specific published image.
# AGILE_TOOLS_IMAGE=ghcr.io/rubiss-projects/agile-tools:v0.1.1
ENCRYPTION_KEY=replace-with-a-32-byte-local-dev-only-key
SESSION_SECRET=replace-with-a-32-byte-local-dev-only-secret

# Self-hosted OIDC SSO only
# AUTH_PROVIDER=oidc
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=agile-tools
# OIDC_CLIENT_SECRET=
# OIDC_CLIENT_AUTH_METHOD=client_secret_basic
# OIDC_REDIRECT_URI=https://agile-tools.example.com/api/oidc/callback
# OIDC_POST_LOGOUT_REDIRECT_URI=https://agile-tools.example.com/
# OIDC_SCOPES=openid profile email
# OIDC_ALLOWED_ISSUERS=https://idp.example.com
# OIDC_WORKSPACE_ID=00000000-0000-4000-8000-000000000011
# OIDC_WORKSPACE_NAME=Agile Tools
# OIDC_DEFAULT_TIMEZONE=UTC
# OIDC_ADMIN_EMAILS=admin@example.com
# OIDC_ADMIN_CLAIM=groups
# OIDC_ADMIN_CLAIM_VALUES=agile-tools-admins
# OIDC_ALLOW_INSECURE_HTTP=false
# Optional: redirect unauthenticated browser page requests directly to SSO.
# APIs, metrics, static assets, and OIDC callback/logout routes are excluded.
# OIDC_AUTO_LOGIN=false
# Optional: max age for Agile Tools OIDC cookies. Effective access still depends
# on the IdP access/refresh token policy and revocation behavior.
# OIDC_SESSION_MAX_AGE_SECONDS=1209600

# Sync
DEFAULT_SYNC_INTERVAL_MINUTES=10
# Maximum runtime (ms) of the Prisma interactive transaction that publishes
# staged Jira sync results. Raised above Prisma's 5 s default so large boards
# can publish atomically. Default: 600000 (10 minutes).
# SYNC_PUBLISH_TRANSACTION_TIMEOUT_MS=600000
# Maximum time (ms) Prisma waits for a connection before starting the publish
# transaction. Default: 30000 (30 seconds).
# SYNC_PUBLISH_TRANSACTION_MAX_WAIT_MS=30000

# Logging
LOG_LEVEL=debug

# Hosted Vercel beta only
# AUTH_PROVIDER=clerk
# SYNC_BACKEND=vercel_queues
# JIRA_CONNECTION_POLICY=cloud_oauth_only
# HOSTED_LAUNCH_TIER=hobby_beta
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# ATLASSIAN_CLIENT_ID=
# ATLASSIAN_CLIENT_SECRET=
# ATLASSIAN_REDIRECT_URI=https://your-vercel-domain.example/api/atlassian/oauth/callback
# ATLASSIAN_SCOPES=read:jira-user read:jira-work offline_access
# CRON_SECRET=
# HOSTED_BETA_TICK_INTERVAL_MINUTES=15
# HOSTED_BETA_MIN_SCHEDULED_SYNC_INTERVAL_MINUTES=1440
# HOSTED_BETA_MANUAL_SYNC_COOLDOWN_MINUTES=360
# HOSTED_BETA_SYNC_CHUNK_TARGET_SECONDS=8
# HOSTED_BETA_SYNC_CHUNK_MAX_SECONDS=30
# HOSTED_BETA_MAX_WORKSPACES=5
# HOSTED_BETA_MAX_CONNECTIONS_PER_WORKSPACE=1
# HOSTED_BETA_MAX_SCOPES_PER_WORKSPACE=1
# HOSTED_BETA_MAX_ORG_MEMBERS=5
# HOSTED_BETA_MAX_ACTIVE_ISSUES_PER_SCOPE=500
# HOSTED_BETA_MAX_COMPLETED_ISSUES_PER_SYNC=1000
# HOSTED_BETA_MAX_SYNC_RUNS_PER_WORKSPACE_PER_DAY=2
# HOSTED_PRISMA_MONTHLY_OP_BUDGET=40000
# HOSTED_VERCEL_FUNCTION_INVOCATION_BUDGET=500000
# HOSTED_VERCEL_QUEUE_OPERATION_BUDGET=500000
# HOSTED_VERCEL_ACTIVE_CPU_HOURS_BUDGET=2

# Optional local Jira bootstrap for docker-compose.jira.yml
# Uncomment and fill these in only if you want the post-setup Jira seed job.
# JIRA_BOOTSTRAP_USERNAME=admin
# JIRA_BOOTSTRAP_PASSWORD=replace-with-your-local-jira-password
# JIRA_SETUP_APPLICATION_TITLE=Agile Tools Local Jira
# JIRA_SETUP_BASE_URL=http://localhost:8080
# JIRA_SETUP_MODE=private
# JIRA_SETUP_ADMIN_DISPLAY_NAME=Agile Tools Local Admin
# JIRA_SETUP_ADMIN_EMAIL=admin@example.test
# JIRA_SETUP_LICENSE_KEY=<optional-host-product-license>
# JIRA_BOOTSTRAP_PROJECT_KEY=AGILE
# JIRA_BOOTSTRAP_PROJECT_NAME=Agile Tools Local Demo
# JIRA_BOOTSTRAP_BOARD_NAME=Agile Tools Kanban
# JIRA_BOOTSTRAP_FILTER_NAME=Agile Tools Kanban Filter
# JIRA_BOOTSTRAP_ISSUE_LABEL=agile-tools-bootstrap
# JIRA_BOOTSTRAP_SAMPLE_ISSUE_COUNT=82
# JIRA_BOOTSTRAP_COMPLETED_STORY_COUNT=72
# JIRA_BOOTSTRAP_IN_PROGRESS_STORY_COUNT=10
# JIRA_BOOTSTRAP_RESET_ISSUES=true
# JIRA_BOOTSTRAP_CREATE_PAT=true
# JIRA_BOOTSTRAP_PAT_NAME=agile-tools-local
# JIRA_BOOTSTRAP_PAT_EXPIRATION_DAYS=30
