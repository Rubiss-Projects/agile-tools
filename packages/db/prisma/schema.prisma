generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ConnectionHealthStatus {
  draft
  validating
  healthy
  unhealthy
  stale
  disabled
}

enum JiraChangelogStrategy {
  subresource
  issue_expand
}

enum JiraAuthType {
  data_center_pat
  cloud_oauth_3lo
}

enum FlowScopeStatus {
  active
  paused
  needs_attention
}

enum SyncRunTrigger {
  scheduled
  manual
}

enum SyncRunStatus {
  queued
  running
  succeeded
  failed
  canceled
}

enum LifecycleEventType {
  status_change
  field_change
  reopened
  completed
}

enum HoldPeriodSource {
  status
  blocked_field
}

enum HostedSyncTaskStatus {
  queued
  running
  completed
  failed
}

enum HostedCapacityReservationKind {
  workspace
  jira_connection
  flow_scope
  org_member
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Workspace {
  id              String   @id @default(uuid())
  name            String   @unique
  clerkOrgId      String?  @unique
  defaultTimezone String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connections                JiraConnection[]
  scopes                     FlowScope[]
  hostedUsageCounters        HostedUsageCounter[]
  hostedCapacityReservations HostedCapacityReservation[]
}

model JiraConnection {
  id                     String                 @id @default(uuid())
  workspaceId            String
  baseUrl                String
  displayName            String?
  authType               JiraAuthType           @default(data_center_pat)
  encryptedSecretRef     String?
  cloudId                String?
  siteUrl                String?
  atlassianAccountId     String?
  oauthScopes            String[]               @default([])
  accessTokenSecretRef   String?
  refreshTokenSecretRef  String?
  accessTokenExpiresAt   DateTime?
  healthStatus           ConnectionHealthStatus @default(draft)
  lastValidatedAt        DateTime?
  lastHealthyAt          DateTime?
  lastErrorCode          String?
  jiraVersion            String?
  jiraDeploymentType     String?
  changelogStrategy      JiraChangelogStrategy?
  capabilitiesDetectedAt DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scopes    FlowScope[]

  // Composite unique enables cross-workspace FK integrity from FlowScope
  @@unique([workspaceId, id])
  @@index([workspaceId])
}

model FlowScope {
  id                     String          @id @default(uuid())
  workspaceId            String
  connectionId           String
  boardId                String
  boardName              String
  timezone               String
  includedIssueTypeIds   String[]
  includedIssueTypeNames String[]        @default([])
  startStatusIds         String[]
  doneStatusIds          String[]
  syncIntervalMinutes    Int
  status                 FlowScopeStatus @default(active)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  workspace           Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Composite FK enforces that connectionId belongs to the same workspace
  connection          JiraConnection        @relation(fields: [workspaceId, connectionId], references: [workspaceId, id])
  holdDefinitions     HoldDefinition[]
  boardSnapshots      BoardSnapshot[]
  syncRuns            SyncRun[]
  hostedSyncTasks     HostedSyncTask[]
  workItems           WorkItem[]
  agingModels         AgingThresholdModel[]
  forecastCache       ForecastResultCache[]
  epicForecastTargets EpicForecastTarget[]

  @@index([workspaceId])
  @@index([connectionId])
}

model BoardSnapshot {
  id                String   @id @default(uuid())
  scopeId           String
  syncRunId         String?
  fetchedAt         DateTime
  columns           Json
  statusIdsByColumn Json
  workflowStatuses  Json?
  projectRefs       Json
  filterId          String?
  createdAt         DateTime @default(now())

  scope   FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  syncRun SyncRun?  @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([scopeId, fetchedAt])
}

// Versioned hold rules — effectiveFrom records when each version became active.
// Application code queries for MAX(effectiveFrom) <= now() to get the current definition.
model HoldDefinition {
  id                  String   @id @default(uuid())
  scopeId             String
  holdStatusIds       String[]
  blockedFieldId      String?
  blockedTruthyValues String[]
  effectiveFrom       DateTime
  updatedBy           String
  createdAt           DateTime @default(now())

  scope FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([scopeId, effectiveFrom])
  @@index([scopeId, effectiveFrom])
}

model SyncRun {
  id           String         @id @default(uuid())
  scopeId      String
  trigger      SyncRunTrigger
  status       SyncRunStatus  @default(queued)
  requestedBy  String?
  startedAt    DateTime?
  finishedAt   DateTime?
  dataVersion  String?
  errorCode    String?
  errorSummary String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  scope           FlowScope           @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  boardSnapshots  BoardSnapshot[]
  stagedWorkItems SyncWorkItemStage[]
  hostedTasks     HostedSyncTask[]
  checkpoint      SyncRunCheckpoint?

  @@index([scopeId, createdAt])
  @@index([scopeId, status])
}

model HostedSyncTask {
  id          String               @id @default(uuid())
  syncRunId   String
  scopeId     String
  phase       String
  cursor      Json?
  status      HostedSyncTaskStatus @default(queued)
  attempt     Int                  @default(0)
  dedupeKey   String               @unique
  lockedAt    DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  syncRun SyncRun   @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  scope   FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([syncRunId, status])
  @@index([scopeId, status])
}

model SyncRunCheckpoint {
  id        String   @id @default(uuid())
  syncRunId String   @unique
  phase     String
  cursor    Json?
  counts    Json
  updatedAt DateTime @updatedAt

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
}

model SyncWorkItemStage {
  id                     String    @id @default(uuid())
  syncRunId              String
  scopeId                String
  jiraIssueId            String
  issueKey               String
  summary                String
  issueTypeId            String
  issueTypeName          String?
  projectId              String
  currentStatusId        String
  currentStatusName      String?
  currentColumn          String?
  assigneeName           String?
  jiraCreatedAt          DateTime
  jiraUpdatedAt          DateTime?
  latestCommentAuthor    String?
  latestCommentBody      String?
  latestCommentCreatedAt DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  reopenedCount          Int       @default(0)
  directUrl              String
  excludedReason         String?
  lifecycleEvents        Json
  stagedAt               DateTime  @default(now())

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@unique([syncRunId, jiraIssueId])
  @@index([syncRunId, id])
  @@index([scopeId, syncRunId])
}

model WorkItem {
  id                     String    @id @default(uuid())
  scopeId                String
  jiraIssueId            String
  issueKey               String
  summary                String
  issueTypeId            String
  issueTypeName          String?
  projectId              String
  currentStatusId        String
  currentStatusName      String?
  currentColumn          String?
  assigneeName           String?
  createdAt              DateTime // Jira creation timestamp — NOT auto-generated
  jiraUpdatedAt          DateTime?
  latestCommentAuthor    String?
  latestCommentBody      String?
  latestCommentCreatedAt DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  reopenedCount          Int       @default(0)
  directUrl              String
  excludedReason         String?
  // Provenance fields
  syncedAt               DateTime  @default(now())
  lastSyncRunId          String?
  updatedAt              DateTime  @updatedAt

  scope           FlowScope                @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  lifecycleEvents WorkItemLifecycleEvent[]
  holdPeriods     HoldPeriod[]

  @@unique([scopeId, jiraIssueId])
  @@index([scopeId, completedAt])
  @@index([scopeId, currentColumn])
  @@index([scopeId, currentStatusId])
  @@index([scopeId, startedAt])
}

model WorkItemLifecycleEvent {
  id             String             @id @default(uuid())
  workItemId     String
  rawChangelogId String?
  eventType      LifecycleEventType
  fromStatusId   String?
  toStatusId     String?
  changedFieldId String?
  changedAt      DateTime

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  // Prevent duplicate derivation for the same changelog entry + event type
  @@unique([workItemId, rawChangelogId, eventType])
  @@index([workItemId, changedAt])
}

model HoldPeriod {
  id          String           @id @default(uuid())
  workItemId  String
  startedAt   DateTime
  endedAt     DateTime?
  source      HoldPeriodSource
  sourceValue String

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  // Non-overlap per (workItemId, source) is enforced via application logic and
  // the btree_gist exclusion constraint in the base migration SQL.
  @@index([workItemId, startedAt])
  @@index([workItemId, endedAt])
}

model AgingThresholdModel {
  id                   String   @id @default(uuid())
  scopeId              String
  historicalWindowDays Int
  sampleSize           Int
  metricBasis          String   @default("cycle_time")
  p50                  Float
  p70                  Float
  p85                  Float
  columnThresholds     Json?
  calculatedAt         DateTime
  dataVersion          String
  lowConfidenceReason  String?
  createdAt            DateTime @default(now())

  scope FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId, calculatedAt])
}

model ForecastResultCache {
  id                   String    @id @default(uuid())
  scopeId              String
  requestHash          String
  sampleMode           String    @default("rolling")
  historicalWindowDays Int?
  sampleStartDate      String?
  sampleEndDate        String?
  iterations           Int
  confidenceLevels     Float[]
  sampleSize           Int
  dataVersion          String
  warnings             Json
  resultPayload        Json
  createdAt            DateTime  @default(now())
  expiresAt            DateTime?

  scope FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([scopeId, requestHash, dataVersion])
  @@index([scopeId, dataVersion])
}

model EpicForecastTarget {
  id                  String    @id @default(uuid())
  scopeId             String
  jiraIssueKey        String
  summary             String
  dueDate             String
  remainingStoryCount Int
  storyCountSource    String    @default("manual")
  epicLinkStoryCount  Int?
  epicLinkIssueKeys   String[]  @default([])
  jiraStoryCount      Int?
  manualStoryCount    Int?
  status              String    @default("active")
  closedAt            DateTime?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  scope FlowScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([scopeId, jiraIssueKey])
  @@index([scopeId, status, dueDate])
}

model HostedUsageBudget {
  id        String   @id @default(uuid())
  key       String   @unique
  limit     Int
  warnAt    Int
  blockAt   Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HostedUsageCounter {
  id          String   @id @default(uuid())
  workspaceId String?
  key         String
  period      String
  value       Int      @default(0)
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key, period])
  @@index([key, period])
}

model HostedCapacityReservation {
  id          String                        @id @default(uuid())
  workspaceId String?
  kind        HostedCapacityReservationKind
  resourceId  String
  createdAt   DateTime                      @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([kind, resourceId])
  @@index([workspaceId, kind])
}
